PORT=3001
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# Python pipeline ayarları
PYTHON_BIN=python
# Model dosyaları (app/models/ altına yerleştirin)
SEG_MODEL_PATH=app/models/segmentation.pth
DMG_MODEL_PATH=app/models/damage.pth
# İsteğe bağlı: main.py konumunu varsayılandan farklı bir yere override etmek için
# PYTHON_MAIN_PY=app/main.py
